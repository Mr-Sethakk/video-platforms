# ==============================================================
# 影视平台后端 · 环境变量配置模板
# ==============================================================
# 使用方式:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的真实 API Key 和密码
#   3. .env 已在 .gitignore 中，不会被提交到 Git
# ==============================================================

# ---------- 数据库 ----------
DB_USERNAME=root
DB_PASSWORD=root

# ---------- Redis ----------
REDIS_PASSWORD=

# ---------- JWT ----------
# 用 openssl rand -base64 32 或在线生成器生成随机字符串
JWT_SECRET=change-me-to-a-random-string

# ---------- DeepSeek AI（可选，用于 Chat 对话）----------
# 注册获取: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here

# ---------- 阿里云百炼 DashScope（可选，用于海报识图找片）----------
# 注册获取: https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=sk-your-key-here
