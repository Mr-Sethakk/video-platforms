# ==============================================================
# 影视平台 · 环境变量配置模板
# ==============================================================
# 使用方式:
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入真实值（数据库密码建议修改，AI Key 按需配置）
#   3. .env 已在 .gitignore 中，不会被提交到 Git
# ==============================================================

# ---------- 数据库 ----------
DB_USERNAME=root
DB_PASSWORD=root

# ---------- Redis ----------
REDIS_PASSWORD=

# ---------- JWT 密钥 ----------
# 生成方式: openssl rand -base64 32
JWT_SECRET=ZGV2LW9ubHktc2VjcmV0LWtleS1mb3ItbG9jYWwtZGV2ZWxvcG1lbnQtbm90LWZvci1wcm9kdWN0aW9u

# ---------- AI 功能（可选）----------
# 不填则 AI 聊天 / 海报识图功能不可用，其他核心功能正常
# DeepSeek 注册: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here
# 阿里云百炼注册: https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=sk-your-key-here
